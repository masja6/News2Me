ANTHROPIC_API_KEY=sk-ant-...
# Optional — kept only if you want to switch provider later:
GEMINI_API_KEY=AIza...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789
# Where operational alerts go (defaults to TELEGRAM_CHAT_ID if empty)
ALERT_CHAT_ID=

# Gmail (SMTP)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Storage
MONGODB_URI=
APP_URL=http://localhost:8000

# Google OAuth (required for user sign-in)
GOOGLE_CLIENT_ID=

# Session signing key (any random string, required in production)
SESSION_SECRET=

# Admin UI (required to access /admin)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# Used to sign unsubscribe links (any random string). If empty, ANTHROPIC_API_KEY is used.
UNSUBSCRIBE_SECRET=
